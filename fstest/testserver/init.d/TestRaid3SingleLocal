#!/usr/bin/env bash
#
# TestRaid3SingleLocal - local-only single reference remote for raid3 comparison tests.
#
# Part of the raid3 test infrastructure. Provisions one local directory used as
# the "single" reference remote when comparing raid3 vs single behavior.
# No Docker; used by go test ./backend/raid3 comparison tests.
#
# Does not use run.bash (avoids flock, which is not available on macOS by default).
#
set -euo pipefail

RUN_BASE="${STATE_DIR:-${XDG_RUNTIME_DIR:-/tmp}/rclone-test-server}"
NAME="$(basename "$0")"
RUN_ROOT="${RUN_BASE}/${NAME}"

start() {
	mkdir -p "${RUN_ROOT}"
	echo type=local
	echo nounc=true
	echo "root=${RUN_ROOT}"
}

status() {
	[[ -d "${RUN_ROOT}" ]]
}

stop() {
	:
}

case "${1:-}" in
	start)
		start
		;;
	stop)
		stop
		;;
	status)
		status
		;;
	reset)
		stop
		rm -rf "${RUN_ROOT}"
		;;
	*)
		echo "usage: $0 {start|stop|reset|status}" >&2
		exit 2
		;;
esac
